export DISPLAY=:0.0

export PATH=~/bin:/usr/local/opt/python@3.8/bin:/usr/local/bin:/usr/local/sbin:$PATH

# Prefer Homebrew Ruby over the macOS system Ruby when it's installed.
# Ruby is keg-only, so Homebrew won't put it on the PATH automatically.
if [ -d "/opt/homebrew/opt/ruby/bin" ]; then
  export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
  # Add gem-installed binaries; glob the version dir so it survives Ruby upgrades.
  for gem_bin in /opt/homebrew/lib/ruby/gems/*/bin; do
    [ -d "$gem_bin" ] && export PATH="$gem_bin:$PATH"
  done
  export LDFLAGS="-L/opt/homebrew/opt/ruby/lib"
  export CPPFLAGS="-I/opt/homebrew/opt/ruby/include"
fi

alias glog='git log --name-status'
alias glogme='git log --name-status --author=$USER'

#for rails
alias ptl="tail -f log/development.log"
alias sc='script/console'

alias psx="ps auxw | grep $1"

function parse_gb {
  cut -c17- .git/HEAD 2> /dev/null
}
PS1="\W \[\033[01;33m\]\$(parse_gb)\[\033[00;37m\]$ "

[[ -r "/usr/local/etc/profile.d/bash_completion.sh" ]] && . "/usr/local/etc/profile.d/bash_completion.sh"
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"
. "$HOME/.cargo/env"

